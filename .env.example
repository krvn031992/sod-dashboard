# ============================================================
# State of Dance — Operating Dashboard · environment
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.
# Only VITE_-prefixed vars are exposed to the browser, and the
# anon key is safe to ship (RLS enforces access). The service
# role key must NEVER live here — keep it server-side only.
# ============================================================

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (Project Settings → API)
VITE_SUPABASE_ANON_KEY=

# ---- Google Sheets / Apps Script (Phase 2+, optional for now) ----
# Deployed Apps Script web-app URL used for endorsement writes and
# calendar/ledger-mirror reads. Server-mediated; no service key in client.
VITE_SHEETS_WEBAPP_URL=
